{
  "parserOptions": {
    "ecmaVersion": 2020,
    "sourceType": "module"
  },
  "rules": {
    "comma-dangle": [
      "error",
      "always-multiline",
      {
        "arrays": "always-multiline"
      }
    ],
    "no-multiple-empty-lines": [
      "error",
      {
        "max": 2
      }
    ],
    "no-unused-vars": [
      "warn"
    ],
    "vue/html-quotes": [
      "error",
      "double"
    ],
    "vue/html-self-closing": [
      "error",
      {
        "html": {
          "void": "always",
          "normal": "never"
        }
      }
    ]
  },
  "extends": [
    "eslint:recommended",
    "plugin:vue/essential"
  ]
}
